{
	"version": "2.0.0",
	"inputs": [
		{
			"id": "testName",
			"type": "promptString",
			"description": "Nom complet du test, ex: collatz_conjecture.test_divide_if_even (plusieurs possibles, séparés par des virgules)"
		}
	],
	"tasks": [
		{
			"label": "Odin: tester l'exercice courant",
			"type": "shell",
			"command": "odin",
			"args": ["test", "${fileDirname}", "-vet"],
			"options": { "cwd": "${fileDirname}" },
			"group": { "kind": "test", "isDefault": true },
			"presentation": { "clear": true },
			"problemMatcher": {
				"owner": "odin",
				"fileLocation": "absolute",
				"pattern": {
					"regexp": "^(.+\\.odin)\\((\\d+):(\\d+)\\)\\s+(.*)$",
					"file": 1,
					"line": 2,
					"column": 3,
					"message": 4
				}
			}
		},
		{
			"label": "Odin: build tests (debug)",
			"type": "shell",
			"command": "odin",
			"args": [
				"build", "${fileDirname}",
				"-build-mode:test",
				"-debug",
				"-o:none",
				"-define:ODIN_TEST_THREADS=1",
				"-define:ODIN_TEST_FANCY=false",
				"-out:${fileDirname}/debug_test.bin"
			],
			"presentation": { "reveal": "silent", "clear": true },
			"problemMatcher": {
				"owner": "odin",
				"fileLocation": "absolute",
				"pattern": {
					"regexp": "^(.+\\.odin)\\((\\d+):(\\d+)\\)\\s+(.*)$",
					"file": 1,
					"line": 2,
					"column": 3,
					"message": 4
				}
			}
		},
		{
			"label": "Odin: build tests (debug, un seul test)",
			"type": "shell",
			"command": "odin",
			"args": [
				"build", "${fileDirname}",
				"-build-mode:test",
				"-debug",
				"-o:none",
				"-define:ODIN_TEST_THREADS=1",
				"-define:ODIN_TEST_FANCY=false",
				"-define:ODIN_TEST_NAMES=${input:testName}",
				"-out:${fileDirname}/debug_test.bin"
			],
			"presentation": { "reveal": "silent", "clear": true },
			"problemMatcher": {
				"owner": "odin",
				"fileLocation": "absolute",
				"pattern": {
					"regexp": "^(.+\\.odin)\\((\\d+):(\\d+)\\)\\s+(.*)$",
					"file": 1,
					"line": 2,
					"column": 3,
					"message": 4
				}
			}
		}
	]
}
